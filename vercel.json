{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": null,
  "outputDirectory": "dist/client",
  "routes": [
    {
      "src": "^/assets/.*",
      "dest": "/$0",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": ".*",
      "dest": "/$0"
    }
  ]
}
